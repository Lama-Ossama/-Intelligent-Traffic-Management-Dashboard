# Local .terraform directories
**/.terraform/*

# Terraform lock file (commit this if you want reproducible provider versions across a team)
# .terraform.lock.hcl

# State files - can contain sensitive data
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Variable files that may contain secrets
*.tfvars
*.tfvars.json
!terraform.tfvars.example

# CLI configuration files
.terraformrc
terraform.rc

# Plan output files
*.tfplan
