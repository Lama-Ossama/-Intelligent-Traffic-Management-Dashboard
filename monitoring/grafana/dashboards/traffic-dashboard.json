{
  "id": null,
  "uid": "traffic-dashboard-overview",
  "title": "Traffic Dashboard Overview",
  "tags": ["traffic", "devops-demo"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Service Up",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "up{job=\"traffic-dashboard\"}", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Records Loaded",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "traffic_dashboard_records_total", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Vehicles",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "traffic_dashboard_vehicles_total", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Average Vehicles / Interval",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "traffic_dashboard_average_vehicles", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "type": "piechart",
      "title": "Traffic Situation Breakdown",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 4 },
      "targets": [
        { "expr": "traffic_dashboard_situation_records", "legendFormat": "{{situation}}", "refId": "A" }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Vehicles Over Time",
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 4 },
      "targets": [
        { "expr": "traffic_dashboard_vehicles_total", "legendFormat": "total vehicles", "refId": "A" },
        { "expr": "traffic_dashboard_average_vehicles", "legendFormat": "avg per interval", "refId": "B" }
      ]
    }
  ]
}
